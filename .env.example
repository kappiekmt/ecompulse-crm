# Supabase — get these from Supabase dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: branded public domain where the app is hosted.
# When set, the Integrations page surfaces /api/inbound/lead and
# /api/webhooks/<service> URLs under this domain instead of the raw Supabase
# function URLs. vercel.json rewrites them to the matching Supabase functions.
# Example: https://coaching.joinecompulse.com
# VITE_PUBLIC_BASE_URL=
